# API keys required for Expo app flows
GOOGLE_API_KEY=your-google-gemini-key
GEMINI_MODEL=gemini-2.5-flash

BROWSERBASE_API_KEY=your-browserbase-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id

# Yelp Fusion API key (junk-hauler search). Optional — haulers list is empty without it.
YELP_API_KEY=your-yelp-fusion-key

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_IP=604800
CACHE_TTL_MUNICIPAL_RULES=86400
CACHE_TTL_DISPOSAL_OPTIONS=43200
CACHE_TTL_TRIAGE=86400
CACHE_TTL_CARD_DETAIL=43200
# 0 ⇒ the onboarding-built location RAG never expires (persists across restarts)
CACHE_TTL_LOCATION_RAG=0

# Agent S (Simular) form-filling over a Browserbase cloud session
AGENT_S_ENABLED=true
AGENT_S_MAX_STEPS=25

EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=3072
VECTOR_DISTANCE_THRESHOLD=0.35

GEOIP_URL=http://ip-api.com/json
GEO_MAX_MATCH_KM=150

# RRR mobile app — optional Supabase JWT verification
SUPABASE_URL=
SUPABASE_ANON_KEY=
ALLOWED_ORIGINS=
AUTH_REQUIRED=false
