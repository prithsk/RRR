# API keys required for Expo app flows
GOOGLE_API_KEY=your-google-gemini-key
GEMINI_MODEL=gemini-2.5-flash

BROWSERBASE_API_KEY=your-browserbase-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id

# Twilio — SMS "bids" blast to local junk haulers + inbound reply webhook.
# Optional: without these, haulers are still discovered but shown as "call only".
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+14155551234
# Set true in production to verify the X-Twilio-Signature on the inbound webhook.
TWILIO_VALIDATE_SIGNATURE=false
# Minimum local haulers the Browserbase discovery agent must surface.
HAULERS_MIN=3
CACHE_TTL_HAULERS=43200
CACHE_TTL_BIDS=3600

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_IP=604800
CACHE_TTL_MUNICIPAL_RULES=86400
CACHE_TTL_DISPOSAL_OPTIONS=43200
CACHE_TTL_TRIAGE=86400
CACHE_TTL_CARD_DETAIL=43200
# 0 ⇒ the onboarding-built location RAG never expires (persists across restarts)
CACHE_TTL_LOCATION_RAG=0

# Agent S (Simular) form-filling over a Browserbase cloud session
AGENT_S_ENABLED=true
AGENT_S_MAX_STEPS=25

EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=3072
VECTOR_DISTANCE_THRESHOLD=0.35

GEOIP_URL=http://ip-api.com/json
GEO_MAX_MATCH_KM=150

# RRR mobile app — optional Supabase JWT verification
SUPABASE_URL=
SUPABASE_ANON_KEY=
ALLOWED_ORIGINS=
AUTH_REQUIRED=false

# --- Sentry error monitoring ---
# Captures silent failures that graceful-degradation fallbacks hide from users.
# Sentry — same DSN works for Python backend and React Native app
SENTRY_DSN=https://your-key@o4511602668077056.ingest.us.sentry.io/your-project-id
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=1.0

# --- Arize Phoenix (OSS) observability ---
# For Phoenix Cloud use the per-space collector endpoint, e.g.
#   https://app.phoenix.arize.com/s/<your-space>
# For self-hosted Phoenix use http://localhost:6006
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_API_KEY=
PHOENIX_PROJECT=rrr-backend
PHOENIX_ENABLED=true
# Prompt A/B switch for the eval before/after loop: baseline | v2
PROMPT_VARIANT=baseline
